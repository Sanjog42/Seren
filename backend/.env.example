# ─── Django Core ─────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-50-chars-minimum
DEBUG=False
# Comma-separated — include your domain, www, and api subdomain
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com

# ─── Database (MySQL via cPanel) ─────────────────────────────────────────────
# cPanel username is prepended to DB name and DB user automatically
# e.g. if cPanel user is "seren123", then DB name is "seren123_serendb"
DB_ENGINE=django.db.backends.mysql
DB_NAME=cpanelusername_serendb
DB_USER=cpanelusername_serenuser
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=3306

# ─── Static & Media ──────────────────────────────────────────────────────────
STATIC_URL=/static/
# Media URL must be absolute so the frontend can load product images cross-origin
MEDIA_URL=https://api.yourdomain.com/media/

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── HTTPS ───────────────────────────────────────────────────────────────────
# Keep False — LiteSpeed handles the HTTPS redirect, not Django
SECURE_SSL_REDIRECT=False

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
# Use a Gmail App Password — NOT your account password
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=Seren <your-gmail@gmail.com>

# ─── Business Emails ─────────────────────────────────────────────────────────
# Receives order invoices (the client/shop owner)
CLIENT_EMAIL=owner@yourdomain.com
# Comma-separated — each receives new-order alert emails
STAFF_EMAIL_LIST=staff1@yourdomain.com,staff2@yourdomain.com
