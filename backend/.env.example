# ─── Django Core ─────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-50-chars-minimum
DEBUG=True
# Comma-separated — include your domain, www, and localhost for local dev
ALLOWED_HOSTS=127.0.0.1,localhost

# ─── Database ────────────────────────────────────────────────────────────────
# Option A: SQLite (easiest for local development — no installation needed)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Option B: MySQL (for production / cPanel hosting — comment out Option A first)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=cpanelusername_serendb
# DB_USER=cpanelusername_serenuser
# DB_PASSWORD=your-database-password
# DB_HOST=localhost
# DB_PORT=3306

# ─── Static & Media ──────────────────────────────────────────────────────────
STATIC_URL=/static/
# For local dev, use relative path. For production, use absolute URL with your domain.
MEDIA_URL=/media/
# MEDIA_URL=https://api.yourdomain.com/media/

# ─── CORS ────────────────────────────────────────────────────────────────────
# For local dev, allow localhost. For production, use your domain.
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# ─── HTTPS ───────────────────────────────────────────────────────────────────
# Keep False — LiteSpeed handles the HTTPS redirect on cPanel, not Django
SECURE_SSL_REDIRECT=False

# ─── Email ───────────────────────────────────────────────────────────────────
# For local dev, use console backend (prints emails to terminal — no SMTP needed)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USE_TLS=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# For production with cPanel email:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=mail.yourdomain.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=noreply@yourdomain.com
# EMAIL_HOST_PASSWORD=your-email-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# For production with Gmail:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-gmail@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password (generate at myaccount.google.com/apppasswords)
# DEFAULT_FROM_EMAIL=Seren <your-gmail@gmail.com>

# ─── Business Emails ─────────────────────────────────────────────────────────
# Receives order invoices (the shop owner)
CLIENT_EMAIL=owner@yourdomain.com
